{
  "name": "esphome-components",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerUser": "vscode",
  "workspaceFolder": "/workspaces/esphome-components",
  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/home/vscode/.codex,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.omp,target=/home/vscode/.omp,type=bind,consistency=cached",
    "source=esphome-components-vscode-server,target=/home/vscode/.vscode-server,type=volume",
    "source=esphome-components-code-server,target=/home/vscode/.local/share/code-server,type=volume",
    "source=esphome-components-code-server-config,target=/home/vscode/.config/code-server,type=volume",
    "source=esphome-components-platformio,target=/home/vscode/.platformio,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esphome.esphome-vscode",
        "llvm-vs-code-extensions.vscode-clangd",
        "openai.chatgpt"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "C_Cpp.default.includePath": [
          "/usr/local/lib/python3.11/dist-packages",
          "/usr/local/lib/python3.11/site-packages",
          "${workspaceFolder}/**"
        ],
        "C_Cpp.default.browse.path": [
          "/usr/local/lib/python3.11/dist-packages",
          "/usr/local/lib/python3.11/site-packages",
          "${workspaceFolder}/**"
        ]
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}
