+CONF_VOLTAGE_OFFSET = "voltage_offset"
+CONF_OUTPUT_ZERO_LEVEL = "output_zero_level"
+CONF_OUTPUT_FULL_SCALE_CURRENT = "output_full_scale_current"
+CONF_RESET_CALIBRATION = "reset"
+CONF_PERSIST = "persist"
