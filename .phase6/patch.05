diff --git a/components/programmable_load/calibration.h b/components/programmable_load/calibration.h
index 249de06..d4f79f8 100644
--- a/components/programmable_load/calibration.h
+++ b/components/programmable_load/calibration.h
@@ -2,11 +2,16 @@
 
 #include <cstdint>
 
-namespace esphome {
-namespace programmable_load {
+namespace programmable_load_core {
 
 static constexpr uint16_t CALIBRATION_VERSION = 1;
 
+enum class CalibrationSource : uint8_t {
+  CONFIGURED = 0,
+  RESTORED,
+  APPLIED,
+};
+
 struct LinearCalibration {
   float scale{1.0f};
   float offset{0.0f};
