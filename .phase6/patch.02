-        cv.Optional(CONF_SETTLE_TIME, default="100ms"):
-            cv.positive_time_period_milliseconds,
-        cv.Optional(CONF_SAMPLE_TIME, default="500ms"):
-            cv.positive_time_period_milliseconds,
-        cv.Optional(CONF_RECOVERY_TIME, default="1s"):
