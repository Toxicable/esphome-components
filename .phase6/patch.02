-        cv.Optional(CONF_REPEATS, default=3): cv.int_range(min=1, max=32),
-        cv.Required(CONF_START): button.button_schema(DcrStartButton),
-        cv.Required(CONF_RESISTANCE): sensor.sensor_schema(
-            unit_of_measurement="mΩ",
-            accuracy_decimals=1,
-        ),
-    }
-)
