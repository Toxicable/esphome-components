-            cv.Optional(CONF_FAN_START_TEMPERATURE, default=35.0): cv.float_,
-            cv.Optional(CONF_FAN_FULL_TEMPERATURE, default=70.0): cv.float_,
-        }
-    ),
-    _validate_cooling,
-)
